  >
    <Col
      lg={8}
      md={10}
      sm={10}
      xs={8}
    >
      <ToggleButtonGroup
        items={
          [
            {
              "disabled": false,
              "label": "Diff",
              "onClick": [Function],
              "toggled": false,
              "tooltip": "When enabled - saves the team grades from the current roster config, and shows that along with the new grades coming from any subsequent edits",
            },
            {
              "label": "History",
              "onClick": [Function],
              "toggled": false,
              "tooltip": "If enabled show player's previous 2 seasons (useful sanity check for projections)",
            },
            {
              "label": "* Mins%",
              "onClick": [Function],
              "toggled": false,
              "tooltip": "Whether to incorporate % of minutes played into adjusted ratings (ie turns it into 'production per team 100 possessions')",
            },
            {
              "label": "Bench",
              "onClick": [Function],
              "toggled": true,
              "tooltip": "If enabled show bench position groups even if they play no minutes (useful if you want to override the minutes)",
            },
            {
              "label": "2-deep",
              "onClick": [Function],
              "toggled": true,
              "tooltip": "Show a two-line PG–C depth chart (by projected minutes) above the Guards / Wings / Bigs sections",
            },
            {
              "label": "Super Sr",
              "onClick": [Function],
              "toggled": true,
              "tooltip": "If enabled, assume seniors with eligibility will return (or you can add them from 'Add New Players' (off-season mode only)",
            },
            {
              "disabled": false,
              "label": "What If?",
              "onClick": [Function],
              "toggled": false,
              "tooltip": "Describes what actually happened for the selected season, and allows editing to explore different scenarios",
            },
            {
              "disabled": false,
              "label": "Review",
              "onClick": [Function],
              "toggled": false,
              "tooltip": "Compares the off-season projection against what actually happened (/is actually happening) the following year",
            },
            {
              "disabled": false,
              "label": "NIL",
              "onClick": [Function],
              "toggled": false,
              "tooltip": "Enable experimental NIL analysis mode",
            },
          ]
        }
      />
